# ── Servidor ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# Orígenes permitidos por CORS (separados por coma)
CORS_ORIGIN=http://localhost:5173

# ── Email (opcional) ──────────────────────────────────────
# Sin estas variables, los envíos de contacto se registran en
# consola en vez de mandarse. Rellénalas para envío real (SMTP).
# SMTP_HOST=smtp.tuproveedor.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=usuario
# SMTP_PASS=contraseña
# CONTACT_TO=hola@hodex.es
# CONTACT_FROM=Hodex <no-reply@hodex.es>
